    "detailsAr": {
      "type": "text"
    },
    "detailsFr": {
      "type": "text"
    },
    "tagsAr": {
      "type": "json"
    },
    "tagsFr": {
      "type": "json"
    },
    "lessons": {
      "type": "json"
    },
    "image": {
      "type": "string"
    },
    "bannerImage": {
      "type": "string"
    }
